<div
  class="flex flex-col gap-4 px-4 md:px-24 py-4 md:py-8 max-w-2xl mx-auto"
  data-controller="csv-import"
>
  <h1 class="text-2xl font-semibold text-white">Import Collection</h1>

  <p class="text-grey-text text-sm">
    Upload a CSV file exported from Archidekt to import cards into your collection.
    The CSV must include <strong class="text-white">Scryfall ID</strong> and <strong class="text-white">Quantity</strong> columns.
  </p>

  <%= form_tag collection_imports_path, multipart: true, class: 'flex flex-col gap-4', data: { action: 'submit->csv-import#submit' } do %>
    <!-- Collection Selection -->
    <div class="px-6 py-4 border rounded-3xl bg-foreground border-highlight text-grey-text">
      <label class="block text-sm font-medium mb-2 text-white">Add cards to:</label>

      <div class="flex items-center gap-4 mb-3">
        <label class="flex items-center gap-2 cursor-pointer">
          <input
            type="radio"
            name="collection_source"
            value="existing"
            checked
            data-action="change->csv-import#toggleSource"
            data-csv-import-target="sourceRadio"
            class="accent-accent-50"
          >
          <span class="text-sm">Existing collection</span>
        </label>

        <label class="flex items-center gap-2 cursor-pointer">
          <input
            type="radio"
            name="collection_source"
            value="new"
            data-action="change->csv-import#toggleSource"
            data-csv-import-target="sourceRadio"
            class="accent-accent-50"
          >
          <span class="text-sm">New collection</span>
        </label>
      </div>

      <div data-csv-import-target="existingSection">
        <% if @collections.any? %>
          <select
            name="collection_id"
            class="
              w-full px-3 py-2 bg-background border border-highlight
              rounded-lg text-grey-text focus:outline-none focus:ring-2
              focus:ring-accent-50
            "
          >
            <% @collections.each do |collection| %>
              <option value="<%= collection.id %>"><%= collection.name %></option>
            <% end %>
          </select>
        <% else %>
          <p class="text-accent-100 text-sm">
            No collections found.
            <%= link_to 'Create one', new_collection_path, class: 'underline hover:text-white' %>
            or select "New collection" above.
          </p>
        <% end %>
      </div>

      <div data-csv-import-target="newSection" class="hidden">
        <input
          type="text"
          name="new_collection_name"
          placeholder="Enter collection name"
          autocomplete="off"
          class="
            w-full px-3 py-2 bg-background border border-highlight
            rounded-lg text-grey-text focus:outline-none focus:ring-2
            focus:ring-accent-50
          "
        >
      </div>

      <label class="flex items-center gap-2 cursor-pointer mt-3">
        <input
          type="checkbox"
          name="skip_existing"
          value="1"
          class="accent-accent-50"
        >
        <span class="text-sm">Skip if already in collection</span>
      </label>
      <p class="text-xs text-grey-text/60 mt-1 ml-6">
        When unchecked, importing a card that already exists will add to its quantity.
      </p>
    </div>

    <!-- File Upload -->
    <div class="px-6 py-4 border rounded-3xl bg-foreground border-highlight text-grey-text">
      <label class="block text-sm font-medium mb-2 text-white">CSV File</label>

      <div class="flex items-center gap-3">
        <label class="
          px-4 py-2 bg-highlight text-white rounded-lg hover:bg-highlight/80
          transition cursor-pointer text-sm
        ">
          Choose File
          <input
            type="file"
            name="csv_file"
            accept=".csv"
            data-action="change->csv-import#fileSelected"
            data-csv-import-target="fileInput"
            class="hidden"
          >
        </label>

        <span data-csv-import-target="fileName" class="text-sm text-grey-text/70">
          No file selected
        </span>
      </div>
    </div>

    <!-- Submit -->
    <div>
      <button
        type="submit"
        data-csv-import-target="submitButton"
        class="
          px-6 py-3 bg-accent-50 text-menu rounded-lg hover:bg-accent-50/80
          transition cursor-pointer font-medium
        "
      >
        Import Cards
      </button>
    </div>
  <% end %>
</div>
