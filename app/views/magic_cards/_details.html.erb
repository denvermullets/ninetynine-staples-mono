<%= turbo_frame_tag "card_details_#{card.id}" do %>
  <div class="grid grid-cols-1 gap-6 p-2 md:grid-cols-3 md:p-8 bg-card-details">
    <div
      class="
        flex flex-row items-center justify-between w-auto mt-4 text-end
        md:hidden
      "
    >
      <% if card.foil_available? %>
        <h3 class="font-normal text-md text-grey-text"><%= card.name %></h3>
      <% end %>
      <p class="text-md text-grey-text">
        <% if card.foil_available? %>
          (R) $<%= card.normal_price %> / (foil) $<%= card.foil_price %>
        <% else %>
          (R) $<%= card.normal_price %>
        <% end %>
      </p>
    </div>

    <div class="flex flex-col items-center w-full md:col-span-1">
      <% if card.double_faced? %>
        <% other_card = card.other_face %>
        <div class="flex flex-col items-center">
          <div
            data-controller="card-flip"
            data-action="click->card-flip#flip"
            class="flip-container cursor-pointer"
          >
            <div data-card-flip-target="card" class="flip-card">
              <div class="flip-card-front">
                <%= image_tag (card.image_medium.presence || ""),
                  class: "object-contain w-full h-auto max-w-md rounded-3xl md:max-w-96",
                  alt: card.name %>
              </div>

              <div class="flip-card-back">
                <%= image_tag (other_card&.image_medium.presence || ""),
                  class: "object-contain w-full h-auto max-w-md rounded-3xl md:max-w-96",
                  alt: other_card&.name %>
              </div>
            </div>
          </div>

          <p class="mt-2 text-sm text-grey-text">
            Click card to see other side
          </p>
        </div>
      <% else %>
        <%= image_tag (card.image_medium.presence || ""),
          class: "object-contain w-full h-auto max-w-md rounded-3xl md:max-w-96",
          alt: card.name %>
      <% end %>

      <% owns_normal = defined?(card_locations) && card_locations&.sum(&:quantity).to_i.positive? %>
      <% owns_foil = defined?(card_locations) && card_locations&.sum(&:foil_quantity).to_i.positive? %>
      <% show_ck_normal = owns_normal && card.ck_buylist_normal_price.to_f.positive? %>
      <% show_ck_foil = owns_foil && card.ck_buylist_foil_price.to_f.positive? %>
      <% if show_ck_normal || show_ck_foil %>
        <div class="flex flex-col items-center gap-3 mt-4 w-full">
          <div class="grid gap-4 text-sm text-grey-text <%= show_ck_normal && show_ck_foil ? 'grid-cols-2' : 'grid-cols-1' %>">
            <% if show_ck_normal %>
              <div class="flex flex-col items-center gap-1">
                <span>Sell: <%= number_to_currency(card.ck_buylist_normal_price) %></span>
                <span class="text-xs">Credit: <%= number_to_currency(card.ck_buylist_normal_price * 1.3) %></span>
              </div>
            <% end %>
            <% if show_ck_foil %>
              <div class="flex flex-col items-center gap-1">
                <span class="text-yellow-400">Foil: <%= number_to_currency(card.ck_buylist_foil_price) %></span>
                <span class="text-xs text-yellow-400">Credit: <%= number_to_currency(card.ck_buylist_foil_price * 1.3) %></span>
              </div>
            <% end %>
          </div>
          <a
            href="https://www.cardkingdom.com/purchasing/mtg_singles?filter%5Bsort%5D=price_desc&filter%5Bsearch%5D=mtg_advanced&filter%5Bname%5D=<%= CGI.escape(card.name) %>&filter%5Bedition%5D=&filter%5Bformat%5D=&filter%5Bfoils%5D=1&filter%5Bsingles%5D=1&filter%5Bprice_op%5D=&filter%5Bprice%5D="
            target="_blank"
            rel="noopener noreferrer"
            class="
              px-4 py-2 bg-accent-50 text-background rounded-lg border
              border-accent-50 hover:bg-foreground hover:border-accent-50
              hover:text-accent-50 font-medium cursor-pointer
            "
          >
            Sell to Card Kingdom
          </a>
        </div>
      <% end %>
    </div>

    <div class="flex flex-col md:col-span-2">
      <div class="mb-6">
        <h3 class="hidden text-lg font-semibold text-nine-white md:block">
          <%= card.name %>
        </h3>

        <p class="hidden text-sm text-grey-text md:block">
          <%= card.boxset.name %>
        </p>
      </div>

      <% if card&.card_side == 'a' || card&.card_side.nil? %>
        <%= render partial: 'shared/cards/card_locations', locals: { card_locations:, magic_card: card, collections:, editable: } %>

        <% if card.price_history.present? %>
          <div class="flex flex-row w-full mt-4">
            <%= render partial: 'magic_cards/price_history', locals: { history: card.price_history } %>
          </div>
        <% end %>
        <% if current_user_admin? %>
          <div class="flex flex-row w-full mt-4">
            <%= button_to 'Delete Card', magic_card_path(card.id), method: :delete,
                data: { turbo_confirm: "Are you sure you want to delete #{card.name}? This action cannot be undone." },
                class: "px-4 py-2 text-sm bg-red-500 text-white rounded hover:bg-red-600" %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
