<div class="grouping-container <%= 'hidden' unless view_mode == 'visual' && grouping_allowed %>">
  <div class="flex flex-col">
    <h3 class="mb-2 text-grey-text">Group By</h3>

    <select
      data-collection-view-target="groupingSelect"
      data-action="change->collection-view#changeGrouping"
      class="
        w-full px-3 py-2 border rounded-md bg-background border-highlight
        text-grey-text focus:border-accent-50 focus:ring-accent-50
      "
    >
      <option value="none" <% if grouping == 'none' %> selected<% end %>>None</option>
      <option value="rarity" <% if grouping == 'rarity' %> selected<% end %>>Rarity</option>
      <option value="color" <% if grouping == 'color' %> selected<% end %>>Color</option>
    </select>

    <p class="mt-2 text-xs text-grey-text">Group cards by boxset</p>
  </div>
</div>
