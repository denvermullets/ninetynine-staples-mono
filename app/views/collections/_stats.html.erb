<div
  class="
flex flex-col w-full min-w-0 gap-6 p-6 border rounded-xl
border-highlight text-grey-text
"
>
  <div class="text-sm truncate"><%= message %></div>

  <div class="text-4xl truncate">
    <% if count.present? %>
      <%= number_with_delimiter(count) %>
    <% else %>
      <%= number_to_currency(value) %>
    <% end %>
  </div>
</div>
