<div
  class="flex flex-col min-h-screen bg-background"
  data-controller="bulk-import"
  data-bulk-import-deck-id-value="<%= @deck.id %>"
  data-bulk-import-deck-path-value="<%= deck_builder_path(@deck) %>"
>
  <!-- Header -->
  <div class="px-4 py-4 border-b border-highlight bg-foreground">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-4">
        <%= link_to deck_builder_path(@deck), class: "text-accent-50 hover:text-accent-400 transition text-sm flex items-center gap-1" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back
        <% end %>

        <div>
          <h1 class="text-xl font-semibold text-white">Bulk Import</h1>
          <p class="text-sm text-grey-text"><%= @deck.name %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="flex-1 px-4 py-6 max-w-2xl mx-auto w-full">
    <%# Phase 1: Paste %>
    <div data-bulk-import-target="pastePhase">
      <p class="mb-3 text-sm text-grey-text">
        Paste a card list, one per line. Format: <code class="text-accent-50">1 Hullbreaker Horror</code> or <code class="text-accent-50">1x Hullbreaker Horror</code>
      </p>

      <textarea
        data-bulk-import-target="textarea"
        rows="12"
        placeholder="1 Hullbreaker Horror&#10;2x Counterspell&#10;1 Sol Ring"
        class="
          w-full p-3 text-sm border rounded-lg bg-foreground border-highlight
          text-grey-text placeholder-grey-text/50 focus:outline-none
          focus:border-accent-50 resize-y
        "
      ></textarea>

      <button
        type="button"
        data-action="click->bulk-import#startImport"
        class="
          mt-3 w-full px-4 py-2.5 text-sm font-medium rounded-lg bg-accent-50
          text-foreground border border-accent-50 hover:bg-foreground
          hover:text-accent-50 transition cursor-pointer
        "
      >
        Start Import
      </button>
    </div>

    <%# Phase 2: Resolve %>
    <div data-bulk-import-target="resolvePhase" class="hidden">
      <div class="mb-4">
        <p data-bulk-import-target="progressText" class="text-sm text-grey-text"></p>
        <div class="mt-1 w-full bg-highlight rounded-full h-1.5">
          <div data-bulk-import-target="progressBar" class="bg-accent-50 h-1.5 rounded-full transition-all" style="width: 0%"></div>
        </div>
      </div>

      <div class="mb-3">
        <h4 class="text-base font-medium text-nine-white">
          <span data-bulk-import-target="cardQuantity"></span>x
          <span data-bulk-import-target="cardName"></span>
        </h4>
      </div>

      <div
        data-bulk-import-target="resultsContainer"
        class="space-y-2"
      ></div>

      <button
        type="button"
        data-action="click->bulk-import#skip"
        class="
          mt-3 w-full px-4 py-2 text-sm border rounded-lg border-highlight
          text-grey-text hover:bg-foreground hover:text-accent-100
          hover:border-accent-100 transition cursor-pointer
        "
      >
        Skip
      </button>

      <button
        type="button"
        data-action="click->bulk-import#cancelImport"
        class="
          mt-2 w-full px-4 py-2 text-sm text-grey-text/60
          hover:text-red-400 transition cursor-pointer
        "
      >
        Cancel Import
      </button>
    </div>

    <%# Phase 3: Summary %>
    <div data-bulk-import-target="summaryPhase" class="hidden">
      <div data-bulk-import-target="summaryContainer"></div>

      <%= link_to "Back to Deck", deck_builder_path(@deck),
        class: "
          mt-4 block text-center w-full px-4 py-2.5 text-sm font-medium rounded-lg bg-accent-50
          text-foreground border border-accent-50 hover:bg-foreground
          hover:text-accent-50 transition
        " %>
    </div>
  </div>

  <%= turbo_frame_tag "deck_modal" %>
</div>
