<% if result[:type] == :owned %>
  <%= render partial: 'search_result_owned', locals: { result: result, deck: deck } %>
<% elsif result[:type] == :browse %>
  <%= render partial: 'search_result_browse', locals: { result: result, deck: deck } %>
<% else %>
  <%= render partial: 'search_result_latest', locals: { result: result, deck: deck } %>
<% end %>
