<%= turbo_frame_tag "deck_modal" do %>
  <dialog
    id="view-combos-dialog"
    class="
      p-0 border-0 md:border rounded-none md:rounded-lg bg-foreground
      md:border-highlight backdrop:bg-black/50 fixed inset-0 md:inset-auto
      md:top-1/2 md:left-1/2 md:-translate-x-1/2 md:-translate-y-1/2 m-0
      max-w-none md:max-w-[95vw] w-full h-full md:w-auto md:h-auto
      md:max-h-[90vh] overflow-hidden
    "
    data-controller="modal"
    data-action="click->modal#closeOnBackdrop keydown.esc->modal#close"
  >
    <div
      class="
        w-full md:w-[900px] p-4 md:p-6 flex flex-col h-full md:h-auto
        md:max-h-[90vh]
      "
      data-modal-target="content"
    >
      <div class="flex items-center justify-between mb-4 shrink-0">
        <h3 class="text-lg font-semibold text-grey-text">
          Combos for <%= magic_card.name %>
        </h3>

        <button
          type="button"
          data-action="click->modal#close"
          class="text-grey-text hover:text-nine-white cursor-pointer"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"
            />
          </svg>
        </button>
      </div>

      <div class="overflow-y-auto flex-1 space-y-6">
        <% card_combos.each_with_index do |deck_combo, idx| %>
          <div class="p-4 rounded-lg border border-highlight bg-background">
            <!-- Combo Header -->
            <div class="flex items-center gap-2 mb-3">
              <% if deck_combo.combo_type == 'included' %>
                <span class="px-2 py-0.5 text-xs font-bold rounded bg-green-500/20 text-green-400 border border-green-500/30">
                  Complete Combo
                </span>
              <% else %>
                <span class="px-2 py-0.5 text-xs font-bold rounded bg-amber-500/20 text-amber-400 border border-amber-500/30">
                  Missing <%= deck_combo.deck_combo_missing_cards.size %> card<%= deck_combo.deck_combo_missing_cards.size == 1 ? '' : 's' %>
                </span>
              <% end %>

              <% if deck_combo.combo.results.present? %>
                <span class="text-sm text-accent-50/75">
                  <%= deck_combo.combo.results %>
                </span>
              <% end %>
            </div>

            <!-- Card Images -->
            <%
              missing_names = deck_combo.deck_combo_missing_cards.map(&:card_name).to_set
              combo_cards_with_images = deck_combo.combo.combo_cards.map do |cc|
                img_card = MagicCard.where(scryfall_oracle_id: cc.oracle_id)
                                    .where(card_side: [nil, 'a'])
                                    .where.not(image_medium: [nil, ''])
                                    .first
                { combo_card: cc, image: img_card, missing: missing_names.include?(cc.card_name) }
              end
            %>

            <div class="flex flex-wrap gap-3 mb-3">
              <% combo_cards_with_images.each do |entry| %>
                <div class="relative cursor-pointer" onclick="
                  const img = this.querySelector('img');
                  if (!img) return;
                  if (img.classList.contains('w-32')) {
                    img.classList.remove('w-32');
                    img.classList.add('w-72');
                  } else {
                    img.classList.remove('w-72');
                    img.classList.add('w-32');
                  }
                ">
                  <% if entry[:image] %>
                    <%= image_tag(entry[:image].image_large || entry[:image].image_medium,
                      alt: entry[:combo_card].card_name,
                      class: "w-32 h-auto rounded-lg shadow transition-all duration-200 #{entry[:missing] ? 'opacity-40' : ''}") %>
                  <% else %>
                    <div class="
                      flex items-center justify-center w-32 h-44 rounded-lg
                      bg-background border border-highlight
                      <%= entry[:missing] ? 'opacity-40' : '' %>
                    ">
                      <span class="text-xs text-grey-text text-center px-2">
                        <%= entry[:combo_card].card_name %>
                      </span>
                    </div>
                  <% end %>

                  <% if entry[:missing] %>
                    <div class="
                      absolute inset-x-0 bottom-2 mx-1 px-1 py-0.5 text-center
                      text-[10px] font-bold rounded bg-amber-500/80 text-white
                    ">
                      Missing
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>

            <!-- Steps -->
            <% if deck_combo.combo.steps.present? %>
              <div class="mb-3">
                <h5 class="text-xs font-semibold text-grey-text mb-1">Steps</h5>
                <ol class="list-decimal list-inside space-y-1 text-sm text-grey-text/85">
                  <% deck_combo.combo.steps.split("\n").reject(&:blank?).each do |step| %>
                    <li><%= step.strip %></li>
                  <% end %>
                </ol>
              </div>
            <% end %>

            <!-- Prerequisites -->
            <% if deck_combo.combo.prerequisites.present? %>
              <div class="mb-3">
                <h5 class="text-xs font-semibold text-grey-text mb-1">Prerequisites</h5>
                <ul class="list-disc list-inside space-y-1 text-sm text-grey-text/75">
                  <% deck_combo.combo.prerequisites.split("\n").reject(&:blank?).each do |prereq| %>
                    <li><%= prereq.strip %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <!-- Spellbook Link -->
            <a href="<%= deck_combo.combo.permalink %>"
               target="_blank"
               rel="noopener noreferrer"
               class="text-xs text-accent-50 hover:underline">
              View on Commander Spellbook
            </a>
          </div>
        <% end %>
      </div>

      <div class="flex justify-end pt-4 mt-4 border-t border-highlight shrink-0">
        <button
          type="button"
          data-action="click->modal#close"
          class="
            px-4 py-2 text-sm transition border rounded-md border-highlight
            text-grey-text hover:bg-foreground hover:text-accent-50
            hover:border-accent-50 cursor-pointer
          "
        >
          Close
        </button>
      </div>
    </div>
  </dialog>
<% end %>
