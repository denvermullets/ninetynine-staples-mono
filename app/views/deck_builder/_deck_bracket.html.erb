<%
  detected = bracket_result&.dig(:detected_bracket)
  detected_level = detected&.level
  declared_level = deck.bracket_level
  game_changer_count = bracket_result&.dig(:game_changer_count) || 0
%>

<div class="flex flex-wrap items-center gap-3 text-sm">
  <% if detected_level %>
    <div class="flex items-center gap-1.5" title="Detected based on deck rules">
      <span class="text-grey-text">Detected:</span>
      <span class="font-bold <%= bracket_text_class(detected_level) %>">
        B<%= detected_level %>
      </span>
      <span class="<%= bracket_text_class(detected_level) %>"><%= detected.name %></span>
    </div>
  <% end %>

  <% if declared_level %>
    <div class="flex items-center gap-1.5" title="Declared by deck owner">
      <span class="text-grey-text">Declared:</span>
      <span class="font-bold <%= bracket_text_class(declared_level) %>">
        B<%= declared_level %>
      </span>
    </div>
  <% end %>

  <div class="flex items-center gap-1.5">
    <span class="text-grey-text">Game Changers:</span>
    <span class="font-semibold text-white"><%= game_changer_count %></span>
  </div>

  <div class="flex items-center gap-1.5">
    <span class="text-grey-text">Combos:</span>
    <span class="font-semibold text-purple-400"><%= combo_count %></span>
  </div>
</div>
