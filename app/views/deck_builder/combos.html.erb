<div
  class="flex flex-col min-h-screen bg-background"
  data-controller="deck-combos"
>
  <!-- Header -->
  <div class="px-4 py-4 border-b border-highlight bg-foreground">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-4">
        <%= link_to deck_builder_path(@deck), class: "text-accent-50 hover:text-accent-400 transition text-sm flex items-center gap-1" do %>
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 19l-7-7 7-7"
            />
          </svg>
          Back
        <% end %>

        <div>
          <h1 class="text-xl font-semibold text-white">
            <% if @filtered_card %>
              Combos for
              <%= @filtered_card.name %>
            <% else %>
              Combos
            <% end %>
          </h1>

          <p class="text-sm text-grey-text">
            <%= @commander_names.present? ? @commander_names : @deck.name %>
          </p>

          <% if @filtered_card %>
            <%= link_to "View all combos", combos_deck_builder_path(@deck),
              class: "text-xs text-accent-50 hover:underline" %>
          <% end %>
        </div>
      </div>

      <div
        class="
          px-3 py-1.5 text-sm border rounded-lg border-highlight
          text-grey-text
        "
      >
        <%= @included_count %> complete &middot; <%= @missing_count %> missing
      </div>
    </div>
  </div>

  <!-- Filter Chips -->
  <div class="px-4 py-3 flex gap-2">
    <button
      data-deck-combos-target="filterBtn"
      data-filter="all"
      data-action="click->deck-combos#filter"
      class="
        px-3 py-1.5 text-sm border rounded-full transition cursor-pointer
        bg-accent-50/20 text-accent-50 border-accent-50/50
      "
    >
      All (<%= @deck_combos.size %>)
    </button>

    <button
      data-deck-combos-target="filterBtn"
      data-filter="complete"
      data-action="click->deck-combos#filter"
      class="
        px-3 py-1.5 text-sm border rounded-full transition cursor-pointer
        text-grey-text border-highlight
      "
    >
      Complete (<%= @included_count %>)
    </button>

    <button
      data-deck-combos-target="filterBtn"
      data-filter="missing"
      data-action="click->deck-combos#filter"
      class="
        px-3 py-1.5 text-sm border rounded-full transition cursor-pointer
        text-grey-text border-highlight
      "
    >
      Missing (<%= @missing_count %>)
    </button>
  </div>

  <!-- Combo List -->
  <div class="flex-1 px-4 pb-8 space-y-3">
    <% @deck_combos.each_with_index do |deck_combo, idx| %>
      <% combo = deck_combo.combo
        is_complete = deck_combo.combo_type == 'included'
        missing_names = deck_combo.deck_combo_missing_cards.map(&:card_name).to_set
        missing_count = deck_combo.deck_combo_missing_cards.size
        combo_title = combo.combo_cards.map(&:card_name).join(' + ')
        border_color = is_complete ? 'border-l-green-500' : 'border-l-amber-500'
        result_tags = combo.results.present? ? combo.results.split("\n").reject(&:blank?).first(3) : []
        is_first = idx == 0 %>

      <div
        data-deck-combos-target="combo"
        data-combo-type="<%= deck_combo.combo_type %>"
        class="border border-highlight rounded-lg bg-foreground overflow-hidden border-l-4 <%= border_color %>"
      >
        <!-- Combo Header (always visible, clickable to toggle) -->
        <button
          type="button"
          data-action="click->deck-combos#toggle"
          class="
            w-full px-4 py-3 flex items-start justify-between gap-3
            cursor-pointer text-left
          "
        >
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1.5 flex-wrap">
              <% if is_complete %>
                <span
                  class="
                    px-2 py-0.5 text-xs font-bold rounded bg-green-500/20
                    text-green-400 border border-green-500/30 shrink-0
                  "
                >
                  Complete
                </span>
              <% else %>
                <span
                  class="
                    px-2 py-0.5 text-xs font-bold rounded bg-amber-500/20
                    text-amber-400 border border-amber-500/30 shrink-0
                  "
                >
                  Missing <%= missing_count %>
                </span>
              <% end %>

              <span class="text-sm font-medium text-white truncate">
                <%= combo_title %>
              </span>
            </div>

            <% if result_tags.any? %>
              <div class="flex flex-wrap gap-1.5">
                <% result_tags.each do |tag| %>
                  <span
                    class="
                      px-2 py-0.5 text-xs rounded-full bg-accent-50/10
                      text-accent-50/75 border border-accent-50/20
                    "
                  >
                    &infin; <%= tag.strip %>
                  </span>
                <% end %>
              </div>
            <% end %>
          </div>

          <svg
            data-chevron
            class="w-5 h-5 text-grey-text shrink-0 mt-1 transition-transform duration-200 <%= 'rotate-180' if is_first %>"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"
            />
          </svg>
        </button>

        <!-- Combo Body -->
        <div data-combo-body class="<%= 'hidden' unless is_first %> px-4 pb-4">
          <!-- Card Images -->
          <% combo_cards_with_images = combo.combo_cards.map do |cc|
              img_card = MagicCard.where(scryfall_oracle_id: cc.oracle_id)
                                  .where(card_side: [nil, 'a'])
                                  .where.not(image_medium: [nil, ''])
                                  .first
              { combo_card: cc, image: img_card, missing: missing_names.include?(cc.card_name) }
            end %>

          <div class="flex flex-wrap gap-3 md:gap-4 mb-4">
            <% combo_cards_with_images.each do |entry| %>
              <div class="flex flex-col items-center gap-1">
                <div class="relative">
                  <% if entry[:image] %>
                    <%= image_tag(entry[:image].image_large || entry[:image].image_medium,
                      alt: entry[:combo_card].card_name,
                      loading: "lazy",
                      data: { action: "click->deck-combos#toggleCard" },
                      class: "w-24 md:w-56 h-auto rounded-lg shadow transition-all duration-200 cursor-pointer #{entry[:missing] ? 'opacity-40' : ''}") %>
                  <% else %>
                    <div class="flex items-center justify-center w-24 md:w-56 h-[8.4rem] md:h-[19.6rem] rounded-lg bg-background border border-highlight <%= entry[:missing] ? 'opacity-40' : '' %>">
                      <span class="text-xs text-grey-text text-center px-2">
                        <%= entry[:combo_card].card_name %>
                      </span>
                    </div>
                  <% end %>

                  <% if entry[:missing] %>
                    <div
                      class="
                        absolute inset-x-0 bottom-1 mx-1 px-1 py-0.5
                        text-center text-[10px] font-bold rounded
                        bg-amber-500/80 text-white
                      "
                    >
                      Missing
                    </div>
                  <% end %>
                </div>

                <span
                  class="
                    text-xs text-grey-text text-center max-w-24
                    md:max-w-44 leading-tight
                  "
                >
                  <%= entry[:combo_card].card_name %>
                </span>
              </div>
            <% end %>
          </div>

          <!-- Steps -->
          <% if combo.steps.present? %>
            <div class="mb-3">
              <h5
                class="
                  text-xs font-semibold uppercase tracking-wider
                  text-grey-text mb-2
                "
              >
                Steps
              </h5>

              <ol class="space-y-1.5">
                <% combo.steps.split("\n").reject(&:blank?).each_with_index do |step, i| %>
                  <li class="flex items-start gap-2.5 text-sm text-grey-text/85">
                    <span
                      class="
                        flex items-center justify-center w-5 h-5 shrink-0
                        rounded-full bg-accent-50/15 text-accent-50 text-xs
                        font-medium mt-0.5
                      "
                    >
                      <%= i + 1 %>
                    </span>

                    <span><%= step.strip %></span>
                  </li>
                <% end %>
              </ol>
            </div>
          <% end %>

          <!-- Prerequisites -->
          <% if combo.prerequisites.present? %>
            <div
              class="
                mb-3 p-3 rounded-lg bg-background/50 border
                border-highlight/50
              "
            >
              <p class="text-xs text-grey-text/60">
                <svg
                  class="w-3.5 h-3.5 inline-block mr-1 -mt-0.5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"
                  />
                </svg>

                <%= combo.prerequisites.split("\n").reject(&:blank?).join('. ') %>
              </p>
            </div>
          <% end %>

          <!-- Spellbook Link -->
          <% if combo.permalink.present? %>
            <a
              href="<%= combo.permalink %>"
              target="_blank"
              rel="noopener noreferrer"
              class="
                text-xs text-accent-50 hover:underline inline-flex
                items-center gap-1
              "
            >
              View on Commander Spellbook
              <svg
                class="w-3 h-3"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                />
              </svg>
            </a>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @deck_combos.empty? %>
      <div class="flex flex-col items-center justify-center py-16 text-grey-text">
        <p class="text-lg mb-2">No combos found</p>

        <p class="text-sm">
          Check for combos from the deck builder to discover potential combos in
          your deck.
        </p>
      </div>
    <% end %>
  </div>
</div>
