<% if violations_result && violations_result[:violations].any? %>
  <div class="p-4 border-l-4 border-amber-500 bg-amber-500/10 rounded-lg">
    <div class="flex items-center gap-2 mb-2">
      <svg class="w-5 h-5 text-amber-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
      </svg>

      <span class="text-sm font-medium text-amber-400">
        Rule Violations (<%= violations_result[:violations].size %>)
      </span>
    </div>

    <ul class="space-y-1 ml-7">
      <% violations_result[:violations].each do |violation| %>
        <li class="text-sm text-grey-text">
          <span class="font-medium text-white"><%= violation[:rule_name] %>:</span>
          <%= violation[:message] %>

          <% if violation[:offending_cards].any? %>
            <span class="text-xs text-grey-text/70">
              — <%= violation[:offending_cards].join(', ') %>
            </span>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>
