<%= turbo_frame_tag "scan_results", class: "block flex-1 overflow-y-auto min-h-0" do %>
  <% if results.blank? %>
    <p class="text-grey-text/70 text-sm">
      No cards found. Try scanning again with better lighting or angle.
    </p>
  <% else %>
    <div class="space-y-3">
      <% results.each do |result| %>
        <%= render partial: 'card_scanner/scan_result', locals: { result: result } %>
      <% end %>
    </div>
  <% end %>
<% end %>
