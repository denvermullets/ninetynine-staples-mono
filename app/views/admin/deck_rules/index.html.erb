<div class="flex items-start justify-center w-full min-h-screen py-8 px-4">
  <div
    class="
  w-full max-w-2xl p-6 border border-foreground bg-foreground rounded-xl
  text-grey-text
  "
  >
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-xl font-bold">Manage Deck Rules</h1>

      <%= link_to 'New Rule', new_admin_deck_rule_path,
          class: 'px-4 py-2 text-sm rounded-md bg-accent-50 text-foreground hover:bg-accent-100 transition' %>
    </div>

    <% if @deck_rules.any? %>
      <div class="space-y-3">
        <% @deck_rules.group_by(&:bracket).each do |bracket, rules| %>
          <div class="mb-4">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-sm font-medium text-white">
                <% if bracket %>
                  <span class="
                  inline-flex items-center px-2 py-0.5 text-xs font-bold rounded-full
                  <%= bracket_badge_classes(bracket.level) %>
                  ">
                    B<%= bracket.level %>
                  </span>

                  <%= bracket.name %>
                <% else %>
                  <span class="
                  inline-flex items-center px-2 py-0.5 text-xs font-bold rounded-full
                  bg-grey-text/20 text-grey-text
                  ">
                    Global
                  </span>

                  Rules (no bracket)
                <% end %>
              </span>
            </div>

            <% rules.each do |rule| %>
              <div
                class="
              flex items-center justify-between p-4 border rounded-lg
              border-highlight bg-background mb-2
              "
              >
                <div class="flex flex-col gap-1">
                  <div class="flex items-center gap-2">
                    <span class="text-sm font-medium text-white">
                      <%= rule.name %>
                    </span>

                    <% unless rule.enabled %>
                      <span class="px-1.5 py-0.5 text-xs rounded bg-red-500/20 text-red-400">
                        Disabled
                      </span>
                    <% end %>

                    <% if rule.applies_to != 'all' %>
                      <span class="px-1.5 py-0.5 text-xs rounded bg-blue-500/20 text-blue-400">
                        <%= rule.applies_to.humanize %>
                      </span>
                    <% end %>
                  </div>

                  <span class="text-xs text-grey-text/70">
                    <%= rule.rule_type.humanize %> = <%= rule.value %>
                  </span>

                  <% if rule.description.present? %>
                    <span class="text-xs text-grey-text/50">
                      <%= rule.description %>
                    </span>
                  <% end %>
                </div>

                <div class="flex items-center gap-2">
                  <%= link_to 'Edit', edit_admin_deck_rule_path(rule),
                      class: 'px-3 py-1 text-sm border rounded-md border-highlight text-grey-text hover:border-accent-50 hover:text-accent-50 transition' %>

                  <%= button_to 'Delete', admin_deck_rule_path(rule),
                      method: :delete,
                      data: { turbo_confirm: "Delete rule '#{rule.name}'?" },
                      class: 'px-3 py-1 text-sm border rounded-md border-highlight text-grey-text hover:border-red-500 hover:text-red-500 transition cursor-pointer' %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-center py-8 text-grey-text/70">
        No deck rules yet. Create brackets first, then add rules.
      </p>
    <% end %>
  </div>
</div>
