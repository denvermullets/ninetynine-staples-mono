<div class="flex items-start justify-center w-full min-h-screen py-8 px-4">
  <div
    class="
      w-full max-w-2xl p-6 border border-foreground bg-foreground rounded-xl
      text-grey-text
    "
  >
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-xl font-bold">Manage Game Changers</h1>

      <%= link_to 'New Game Changer', new_admin_game_changer_path,
          class: 'px-4 py-2 text-sm rounded-md bg-accent-50 text-foreground hover:bg-accent-100 transition' %>
    </div>

    <% if @game_changers.any? %>
      <div class="space-y-3">
        <% @game_changers.each do |gc| %>
          <div
            class="
              flex items-center justify-between p-4 border rounded-lg
              border-highlight bg-background
            "
          >
            <div class="flex flex-col gap-1">
              <span class="text-sm font-medium text-white">
                <%= gc.card_name %>
              </span>

              <% if gc.reason.present? %>
                <span class="text-xs text-grey-text/70">
                  <%= gc.reason %>
                </span>
              <% end %>
            </div>

            <div class="flex items-center gap-2">
              <%= link_to 'Edit', edit_admin_game_changer_path(gc),
                  class: 'px-3 py-1 text-sm border rounded-md border-highlight text-grey-text hover:border-accent-50 hover:text-accent-50 transition' %>

              <%= button_to 'Delete', admin_game_changer_path(gc),
                  method: :delete,
                  data: { turbo_confirm: "Remove '#{gc.card_name}' from game changers?" },
                  class: 'px-3 py-1 text-sm border rounded-md border-highlight text-grey-text hover:border-red-500 hover:text-red-500 transition cursor-pointer' %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-center py-8 text-grey-text/70">
        No game changers yet. Add one to get started.
      </p>
    <% end %>
  </div>
</div>
