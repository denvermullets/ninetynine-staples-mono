<div class="flex items-start justify-center w-full min-h-screen py-8 px-4">
  <div
    class="
      w-full max-w-4xl p-6 border border-foreground bg-foreground rounded-xl
      text-grey-text
    "
  >
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-xl font-bold">Manage Game Changers</h1>

      <%= link_to 'New Game Changer', new_admin_game_changer_path,
          class: 'px-4 py-2 text-sm rounded-md border border-accent-50 bg-accent-50 text-foreground hover:bg-transparent hover:text-accent-50 transition' %>
    </div>

    <% if @grouped_game_changers.any? %>
      <div class="columns-1 lg:columns-2 gap-6 space-y-4">
        <% @grouped_game_changers.each do |group_name, game_changers| %>
          <div class="break-inside-avoid mb-4">
            <!-- Group Header -->
            <div class="flex items-center gap-2 pb-2 mb-1 border-b border-highlight">
              <%= render partial: 'color_icon', locals: { color_name: group_name } %>
              <span class="font-semibold text-grey-text"><%= group_name %></span>
              <span class="text-grey-text">(<%= game_changers.size %>)</span>
            </div>

            <!-- Card Rows -->
            <div class="space-y-0.5">
              <% game_changers.each do |gc| %>
                <div class="flex items-center gap-2 py-0.5 text-sm group">
                  <span class="flex-1 truncate font-medium text-grey-text">
                    <%= gc.card_name %>

                    <% if gc.reason.present? %>
                      <span class="text-xs font-normal text-grey-text/50">
                        — <%= gc.reason %>
                      </span>
                    <% end %>
                  </span>

                  <div class="flex items-center gap-1 shrink-0 opacity-0 group-hover:opacity-100 transition-opacity">
                    <%= link_to edit_admin_game_changer_path(gc),
                        class: 'p-1 text-grey-text/70 hover:text-accent-50 transition',
                        title: 'Edit' do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                      </svg>
                    <% end %>

                    <%= button_to admin_game_changer_path(gc),
                        method: :delete,
                        data: { turbo_confirm: "Remove '#{gc.card_name}' from game changers?" },
                        class: 'p-1 text-grey-text/70 hover:text-red-500 transition cursor-pointer',
                        title: 'Delete' do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                      </svg>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-center py-8 text-grey-text/70">
        No game changers yet. Add one to get started.
      </p>
    <% end %>
  </div>
</div>
